{
  "$description": "StatusBadge tokens. Semantic pairing: bg+text always together for WCAG compliance.",
  "status-badge": {
    "radius":       { "$type": "dimension", "$value": "{radius.xs}", "$description": "2px — not pill, not square. Surgical." },
    "padding-x":    { "$type": "dimension", "$value": "{spacing.2}" },
    "padding-y":    { "$type": "dimension", "$value": "{spacing.1}" },
    "font-size":    { "$type": "dimension", "$value": "{font.size.12}" },
    "font-weight":  { "$type": "fontWeight", "$value": "{font.weight.semibold}" },
    "letter-spacing":{ "$type": "dimension", "$value": "{font.letterSpacing.wide}" },
    "default": {
      "bg":   { "$type": "color", "$value": "{neutral.100}" },
      "text": { "$type": "color", "$value": "{neutral.700}" }
    },
    "active": {
      "bg":   { "$type": "color", "$value": "{info.50}" },
      "text": { "$type": "color", "$value": "{info.700}" }
    },
    "completed": {
      "bg":   { "$type": "color", "$value": "{sage.50}" },
      "text": { "$type": "color", "$value": "{sage.700}" }
    },
    "warning": {
      "bg":   { "$type": "color", "$value": "{warning.50}" },
      "text": { "$type": "color", "$value": "{warning.700}" }
    },
    "error": {
      "bg":   { "$type": "color", "$value": "{error.50}" },
      "text": { "$type": "color", "$value": "{error.700}" }
    },
    "offline": {
      "bg":   { "$type": "color", "$value": "{neutral.200}" },
      "text": { "$type": "color", "$value": "{neutral.600}" }
    }
  }
}
