{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/work/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:DM Sans|Cormorant Garamond))/i]",
        "message": "Font not provided by the design system. Available: DM Sans, Cormorant Garamond."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|disabled|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, disabled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|label|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: variant, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='PrincipleCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:annotation|principle|description|index|key|ref|className|style|children)$/]",
        "message": "<PrincipleCard> doesn't accept that prop. Declared props: annotation, principle, description, index."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|problem|tags|role|previewSrc|previewLabel|key|ref|className|style|children)$/]",
        "message": "<ProjectCard> doesn't accept that prop. Declared props: title, problem, tags, role, previewSrc, previewLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuoteBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|attribution|context|size|key|ref|className|style|children)$/]",
        "message": "<QuoteBlock> doesn't accept that prop. Declared props: quote, attribution, context, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Status'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Status> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Text'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|as|children|key|ref|className|style|children)$/]",
        "message": "<Text> doesn't accept that prop. Declared props: variant, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|help|error|containerStyle|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, help, error, containerStyle."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
